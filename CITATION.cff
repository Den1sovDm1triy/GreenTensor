  # paper, and verify the per-paper author list. Year (2024) is from the IEEE
  # catalog; the URL is the IEEE Xplore document.
  - type: conference-paper
    title: "GreenTensor: Efficient Electromagnetic Scattering Analysis on Heterogeneous Spherical Structures"
    year: 2024
    url: "https://ieeexplore.ieee.org/document/10615009"
